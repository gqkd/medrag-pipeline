# ── LLM Provider ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here

# ── Biomedical APIs (free, no key required for PubMed) ────
# PubMed: optional but increases rate limit from 3 to 10 req/s
PUBMED_API_KEY=your-ncbi-key-here
PUBMED_EMAIL=your-email@example.com

# OpenFDA: optional, increases rate limit
OPENFDA_API_KEY=your-openfda-key-here

# ── LangSmith (optional, for tracing & debugging) ─────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_your-key-here
LANGCHAIN_PROJECT=medrag-pipeline

# ── App Config ────────────────────────────────────────────
VECTOR_STORE_PATH=./data/processed/faiss_index
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
